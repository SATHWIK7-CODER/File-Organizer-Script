import os
import shutil
from pathlib import Path

def organize_folder(target_dir):
    # Define your categories and their associated extensions
    FILE_TYPES = {
        "Images": [".jpg", ".jpeg", ".png", ".gif", ".bmp", ".svg", ".webp"],
        "Documents": [".pdf", ".docx", ".doc", ".txt", ".xlsx", ".pptx", ".csv"],
        "Videos": [".mp4", ".mov", ".avi", ".mkv", ".wmv"],
        "Audio": [".mp3", ".wav", ".flac", ".m4a"],
        "Archives": [".zip", ".tar", ".rar", ".7z"],
        "Scripts": [".py", ".js", ".html", ".css", ".cpp", ".sh"]
    }

    # Convert string path to a Path object
    base_path = Path(target_dir)

    if not base_path.exists():
        print(f"Error: The directory '{target_dir}' does not exist.")
        return

    # Iterate through all items in the folder
    for item in base_path.iterdir():
        # Skip directories, we only want to move files
        if item.is_dir():
            continue

        # Get the file extension (lowercase for matching)
        extension = item.suffix.lower()
        
        # Determine the destination folder
        moved = False
        for category, extensions in FILE_TYPES.items():
            if extension in extensions:
                dest_folder = base_path / category
                
                # Create the category folder if it doesn't exist
                dest_folder.mkdir(exist_ok=True)
                
                # Move the file
                try:
                    shutil.move(str(item), str(dest_folder / item.name))
                    print(f"Moved: {item.name} -> {category}/")
                except Exception as e:
                    print(f"Could not move {item.name}: {e}")
                
                moved = True
                break
        
        # Optional: Move unknown files to an 'Others' folder
        if not moved:
            others_folder = base_path / "Others"
            others_folder.mkdir(exist_ok=True)
            shutil.move(str(item), str(others_folder / item.name))
            print(f"Moved: {item.name} -> Others/")

if __name__ == "__main__":
    # Replace '.' with the full path of the folder you want to clean
    # e.g., "/Users/YourName/Downloads"
    path_to_clean = input("Enter the full path of the folder to organize: ").strip()
    organize_folder(path_to_clean)
